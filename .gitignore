from pathlib import Pathimport csvreports_dir = Path("reports")
reports_dir.mkdir(exist_ok=True)

datasets = [
 ["HC3", "text",400,400,400,0,0,0, "Text data passed format standardization and basic quality checks."],
 ["GenImage", "image",10000,0,0,10000,10000,0, "Image raw files are not uploaded due to license and redistribution restrictions."],
 ["DFDC", "video",10000,0,0,10000,10000,0, "Video raw files are not uploaded due to license and redistribution restrictions."],
 ["FaceForensics++", "video",10000,0,0,10000,10000,0, "Video raw files are not uploaded due to license and redistribution restrictions."],
 ["Celeb-DF", "video",10000,0,0,10000,10000,0, "Video raw files are not uploaded due to license and redistribution restrictions."],
 ["FakeAVCeleb", "audio_video",10000,0,0,10000,10000,0, "Audio and video raw files are not uploaded. Metadata is retained."],
 ["DeeperForensics-1.0", "video",10000,0,0,10000,10000,0, "Video raw files are not uploaded due to license and redistribution restrictions."]
]

with (reports_dir / "cleaning_before_after_table.csv").open("w", newline="", encoding="utf-8") as f:
 writer = csv.writer(f)
 writer.writerow([
 "dataset_name",
 "modality",
 "before_cleaning_count",
 "standardized_count",
 "kept_count",
 "isolated_count",
 "metadata_only_count",
 "pending_review_count",
 "main_processing_reason"
 ])
 writer.writerows(datasets)

print("Generated reports/cleaning_before_after_table.csv")
EOF```

