 },
 "license_status": {
 "type": "string",
 "enum": ["allowed", "restricted", "unknown"]
 },
 "processing_status": {
 "type": "string",
 "enum": ["kept", "isolated_license", "metadata_only", "pending_review", "rejected"]
 },
