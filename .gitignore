###23. `scripts/validate_schema.py`

```bashcat > scripts/validate_schema.py <<'EOF'
import jsonfrom pathlib import Pathrequired_fields = [
 "sample_id",
 "dataset_name",
 "modality",
 "mapped_aigc_label",
 "risk_type",
 "processing_status"
]

sample_path = Path("data/sample_metadata.jsonl")

def main():
 if not sample_path.exists():
 print("Missing data/sample_metadata.jsonl")
 return total =0 errors = []

 with sample_path.open("r", encoding="utf-8") as f:
 for line_no, line in enumerate(f, start=1):
 total +=1 item = json.loads(line)
 missing = [field for field in required_fields if field not in item]
 if missing:
 errors.append((line_no, missing))

 print(f"checked_records={total}")
 print(f"error_records={len(errors)}")

 for line_no, missing in errors:
 print(f"line={line_no}, missing={missing}")

if __name__ == "__main__":
 main()
EOF```

