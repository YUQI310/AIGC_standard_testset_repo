###25. `scripts/clean.py`

```bashcat > scripts/clean.py <<'EOF'
"""
Placeholder cleaning script for the public dataset quality validation project.

Current-stage rule:
1. HC3 text samples can be standardized and retained.
2. Image/video/audio datasets are metadata-only in this repository.
3. License-restricted datasets are isolated and raw files are not uploaded.
4. Extreme-risk samples are isolated; metadata and risk labels are retained in controlled environment.
"""

def assign_processing_status(dataset_name: str, modality: str, license_status: str) -> str:
 if dataset_name == "HC3" and license_status == "allowed":
 return "kept"
 if modality in {"image", "video", "audio", "audio_video"}:
 return "metadata_only"
 if license_status in {"restricted", "unknown"}:
 return "isolated_license"
 return "pending_review"


if __name__ == "__main__":
 examples = [
 ("HC3", "text", "allowed"),
 ("FakeAVCeleb", "audio_video", "restricted"),
 ("DFDC", "video", "restricted")
 ]
 for item in examples:
 print(item, assign_processing_status(*item))
EOF```

